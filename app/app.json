{
  "expo": {
    "name": "Waaice",
    "slug": "waaice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Waaice needs microphone access for voice commands.",
        "NSSpeechRecognitionUsageDescription": "Waaice uses speech recognition to transcribe voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.barnes_vidit.waaice"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e"
        }
      ]
    ],
    "scheme": "waaice",
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6b177cd0-1666-42a6-9ec4-6bac543b6e8c"
      }
    }
  }
}
